# ============================================
# DR Invoicing & Inventory System
# ============================================

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dr_invoicing
DB_USER=postgres
DB_PASSWORD=postgres123
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT Authentication
JWT_SECRET=cambiar-este-secreto-en-produccion
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=cambiar-este-refresh-secreto-en-produccion
JWT_REFRESH_EXPIRES_IN=7d

# Backend
BACKEND_PORT=3001
NODE_ENV=development

# Frontend
NUXT_PUBLIC_API_BASE=http://localhost:3001/api

# DGII e-CF Configuration
DGII_ENVIRONMENT=TesteCF
# TesteCF = https://ecf.dgii.gov.do/testecf
# CerteCF = https://ecf.dgii.gov.do/certecf
# eCF     = https://ecf.dgii.gov.do/ecf
DGII_BASE_URL=https://ecf.dgii.gov.do/testecf
DGII_RNC=
DGII_CERT_PATH=./certs/certificate.p12
DGII_CERT_PASSWORD=

# File Storage
UPLOAD_DIR=./uploads
