generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// Empresa y Configuracion
// ============================================

model Company {
  id                  String    @id @default(uuid()) @db.Uuid
  rnc                 String    @unique @db.VarChar(11)
  businessName        String    @map("business_name") @db.VarChar(200)
  tradeName           String?   @map("trade_name") @db.VarChar(200)
  address             String
  municipality        String    @db.VarChar(100)
  province            String    @db.VarChar(100)
  phone               String?   @db.VarChar(20)
  email               String?   @db.VarChar(200)
  website             String?   @db.VarChar(200)
  logoUrl             String?   @map("logo_url") @db.VarChar(500)
  // e-CF Config
  ecfEnvironment      String    @default("TesteCF") @map("ecf_environment") @db.VarChar(20)
  digitalCertPath     String?   @map("digital_cert_path") @db.VarChar(500)
  digitalCertPasswordEnc String? @map("digital_cert_password_enc")
  ecfToken            String?   @map("ecf_token")
  ecfTokenExpiry      DateTime? @map("ecf_token_expiry") @db.Timestamptz()
  // Fiscal
  taxRegime           String?   @map("tax_regime") @db.VarChar(50)
  isEcfEnabled        Boolean   @default(false) @map("is_ecf_enabled")
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  branches            Branch[]
  users               User[]
  roles               Role[]
  customers           Customer[]
  suppliers           Supplier[]
  productCategories   ProductCategory[]
  products            Product[]
  invoices            Invoice[]
  purchaseOrders      PurchaseOrder[]
  ecfSequences        EcfSequence[]
  priceLists          PriceList[]
  subscription        Subscription?
  tenantFeatureFlags  TenantFeatureFlag[]

  @@map("companies")
}

model Branch {
  id           String    @id @default(uuid()) @db.Uuid
  companyId    String    @map("company_id") @db.Uuid
  name         String    @db.VarChar(200)
  code         String    @db.VarChar(20)
  address      String?
  municipality String?   @db.VarChar(100)
  province     String?   @db.VarChar(100)
  phone        String?   @db.VarChar(20)
  isMain       Boolean   @default(false) @map("is_main")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  company      Company     @relation(fields: [companyId], references: [id])
  warehouses   Warehouse[]
  users        User[]
  invoices     Invoice[]
  ecfSequences EcfSequence[]

  @@unique([companyId, code])
  @@map("branches")
}

model Warehouse {
  id          String   @id @default(uuid()) @db.Uuid
  branchId    String   @map("branch_id") @db.Uuid
  name        String   @db.VarChar(200)
  code        String   @db.VarChar(20)
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  branch             Branch              @relation(fields: [branchId], references: [id])
  inventoryStock     InventoryStock[]
  inventoryMovements InventoryMovement[]
  purchaseOrders     PurchaseOrder[]

  @@map("warehouses")
}

// ============================================
// Usuarios y Permisos
// ============================================

model User {
  id           String    @id @default(uuid()) @db.Uuid
  companyId    String    @map("company_id") @db.Uuid
  email        String    @unique @db.VarChar(200)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  firstName    String    @map("first_name") @db.VarChar(100)
  lastName     String    @map("last_name") @db.VarChar(100)
  phone        String?   @db.VarChar(20)
  roleId       String    @map("role_id") @db.Uuid
  branchId     String?   @map("branch_id") @db.Uuid
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at") @db.Timestamptz()
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  company            Company             @relation(fields: [companyId], references: [id])
  role               Role                @relation(fields: [roleId], references: [id])
  branch             Branch?             @relation(fields: [branchId], references: [id])
  invoicesCreated    Invoice[]           @relation("InvoiceCreatedBy")
  invoicesUpdated    Invoice[]           @relation("InvoiceUpdatedBy")
  paymentsCreated    Payment[]
  inventoryMovements InventoryMovement[]
  purchaseOrders     PurchaseOrder[]

  @@map("users")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  companyId   String   @map("company_id") @db.Uuid
  name        String   @db.VarChar(100)
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  company     Company          @relation(fields: [companyId], references: [id])
  users       User[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String @id @default(uuid()) @db.Uuid
  code        String @unique @db.VarChar(100)
  module      String @db.VarChar(50)
  description String?

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// ============================================
// Clientes y Proveedores
// ============================================

model Customer {
  id           String   @id @default(uuid()) @db.Uuid
  companyId    String   @map("company_id") @db.Uuid
  rncCedula    String?  @map("rnc_cedula") @db.VarChar(11)
  businessName String   @map("business_name") @db.VarChar(200)
  tradeName    String?  @map("trade_name") @db.VarChar(200)
  customerType String   @map("customer_type") @db.VarChar(20)
  address      String?
  municipality String?  @db.VarChar(100)
  province     String?  @db.VarChar(100)
  phone        String?  @db.VarChar(20)
  email        String?  @db.VarChar(200)
  creditLimit  Decimal  @default(0) @map("credit_limit") @db.Decimal(15, 2)
  creditDays   Int      @default(0) @map("credit_days")
  balance      Decimal  @default(0) @db.Decimal(15, 2)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  company  Company   @relation(fields: [companyId], references: [id])
  invoices Invoice[]
  payments Payment[]

  @@map("customers")
}

model Supplier {
  id           String   @id @default(uuid()) @db.Uuid
  companyId    String   @map("company_id") @db.Uuid
  rnc          String   @db.VarChar(11)
  businessName String   @map("business_name") @db.VarChar(200)
  tradeName    String?  @map("trade_name") @db.VarChar(200)
  contactName  String?  @map("contact_name") @db.VarChar(200)
  address      String?
  phone        String?  @db.VarChar(20)
  email        String?  @db.VarChar(200)
  paymentTerms Int      @default(30) @map("payment_terms")
  balance      Decimal  @default(0) @db.Decimal(15, 2)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  company        Company         @relation(fields: [companyId], references: [id])
  purchaseOrders PurchaseOrder[]

  @@map("suppliers")
}

// ============================================
// Productos e Inventario
// ============================================

model ProductCategory {
  id        String   @id @default(uuid()) @db.Uuid
  companyId String   @map("company_id") @db.Uuid
  parentId  String?  @map("parent_id") @db.Uuid
  name      String   @db.VarChar(200)
  code      String?  @db.VarChar(20)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  company  Company           @relation(fields: [companyId], references: [id])
  parent   ProductCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children ProductCategory[] @relation("CategoryTree")
  products Product[]

  @@map("product_categories")
}

model UnitOfMeasure {
  id           String @id @default(uuid()) @db.Uuid
  code         String @unique @db.VarChar(10)
  name         String @db.VarChar(100)
  abbreviation String @db.VarChar(10)

  products     Product[]
  invoiceItems InvoiceItem[]

  @@map("units_of_measure")
}

model Product {
  id             String   @id @default(uuid()) @db.Uuid
  companyId      String   @map("company_id") @db.Uuid
  categoryId     String?  @map("category_id") @db.Uuid
  unitId         String   @map("unit_id") @db.Uuid
  sku            String?  @db.VarChar(50)
  barcode        String?  @db.VarChar(50)
  name           String   @db.VarChar(200)
  description    String?
  productType    String   @map("product_type") @db.VarChar(20)
  // Prices
  costPrice      Decimal  @default(0) @map("cost_price") @db.Decimal(15, 4)
  salePrice      Decimal  @map("sale_price") @db.Decimal(15, 4)
  minSalePrice   Decimal? @map("min_sale_price") @db.Decimal(15, 4)
  // Tax
  taxType        String   @default("18") @map("tax_type") @db.VarChar(20)
  isTaxable      Boolean  @default(true) @map("is_taxable")
  // Inventory
  trackInventory Boolean  @default(true) @map("track_inventory")
  minStock       Decimal  @default(0) @map("min_stock") @db.Decimal(15, 4)
  maxStock       Decimal? @map("max_stock") @db.Decimal(15, 4)
  // DGII
  bienOServicio  String   @default("1") @map("bien_o_servicio") @db.VarChar(5)
  isActive       Boolean  @default(true) @map("is_active")
  imageUrl       String?  @map("image_url") @db.VarChar(500)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  company            Company              @relation(fields: [companyId], references: [id])
  category           ProductCategory?     @relation(fields: [categoryId], references: [id])
  unit               UnitOfMeasure        @relation(fields: [unitId], references: [id])
  inventoryStock     InventoryStock[]
  inventoryMovements InventoryMovement[]
  invoiceItems       InvoiceItem[]
  purchaseOrderItems PurchaseOrderItem[]
  priceListItems     PriceListItem[]

  @@unique([companyId, sku])
  @@map("products")
}

model InventoryStock {
  id            String   @id @default(uuid()) @db.Uuid
  productId     String   @map("product_id") @db.Uuid
  warehouseId   String   @map("warehouse_id") @db.Uuid
  quantity      Decimal  @default(0) @db.Decimal(15, 4)
  reservedQty   Decimal  @default(0) @map("reserved_qty") @db.Decimal(15, 4)
  avgCost       Decimal  @default(0) @map("avg_cost") @db.Decimal(15, 4)
  lastCountDate DateTime? @map("last_count_date") @db.Timestamptz()
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([productId, warehouseId])
  @@map("inventory_stock")
}

model InventoryMovement {
  id            String   @id @default(uuid()) @db.Uuid
  companyId     String   @map("company_id") @db.Uuid
  productId     String   @map("product_id") @db.Uuid
  warehouseId   String   @map("warehouse_id") @db.Uuid
  movementType  String   @map("movement_type") @db.VarChar(30)
  quantity      Decimal  @db.Decimal(15, 4)
  unitCost      Decimal? @map("unit_cost") @db.Decimal(15, 4)
  referenceType String?  @map("reference_type") @db.VarChar(50)
  referenceId   String?  @map("reference_id") @db.Uuid
  notes         String?
  createdBy     String   @map("created_by") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  user      User      @relation(fields: [createdBy], references: [id])

  @@map("inventory_movements")
}

model PriceList {
  id        String   @id @default(uuid()) @db.Uuid
  companyId String   @map("company_id") @db.Uuid
  name      String   @db.VarChar(100)
  isDefault Boolean  @default(false) @map("is_default")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  company Company         @relation(fields: [companyId], references: [id])
  items   PriceListItem[]

  @@map("price_lists")
}

model PriceListItem {
  id          String  @id @default(uuid()) @db.Uuid
  priceListId String  @map("price_list_id") @db.Uuid
  productId   String  @map("product_id") @db.Uuid
  price       Decimal @db.Decimal(15, 4)

  priceList PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id])

  @@unique([priceListId, productId])
  @@map("price_list_items")
}

// ============================================
// Facturacion e-CF
// ============================================

model EcfSequence {
  id             String    @id @default(uuid()) @db.Uuid
  companyId      String    @map("company_id") @db.Uuid
  branchId       String?   @map("branch_id") @db.Uuid
  ecfType        String    @map("ecf_type") @db.VarChar(5)
  prefix         String    @db.VarChar(3)
  rangeFrom      BigInt    @map("range_from")
  rangeTo        BigInt    @map("range_to")
  currentNumber  BigInt    @map("current_number")
  expiryDate     DateTime? @map("expiry_date") @db.Date
  isActive       Boolean   @default(true) @map("is_active")
  alertThreshold Int       @default(100) @map("alert_threshold")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  company  Company   @relation(fields: [companyId], references: [id])
  branch   Branch?   @relation(fields: [branchId], references: [id])
  invoices Invoice[]

  @@map("ecf_sequences")
}

model Invoice {
  id               String    @id @default(uuid()) @db.Uuid
  companyId        String    @map("company_id") @db.Uuid
  branchId         String    @map("branch_id") @db.Uuid
  customerId       String?   @map("customer_id") @db.Uuid
  // Numbering
  invoiceNumber    String    @map("invoice_number") @db.VarChar(30)
  encf             String?   @db.VarChar(13)
  encfSeqId        String?   @map("encf_seq_id") @db.Uuid
  ecfType          String    @map("ecf_type") @db.VarChar(5)
  // Dates
  issueDate        DateTime  @map("issue_date") @db.Date
  dueDate          DateTime? @map("due_date") @db.Date
  // Currency
  currencyCode     String    @default("DOP") @map("currency_code") @db.VarChar(3)
  exchangeRate     Decimal   @default(1) @map("exchange_rate") @db.Decimal(15, 6)
  // Totals
  subtotal         Decimal   @default(0) @db.Decimal(15, 2)
  discountTotal    Decimal   @default(0) @map("discount_total") @db.Decimal(15, 2)
  taxableBase18    Decimal   @default(0) @map("taxable_base_18") @db.Decimal(15, 2)
  taxableBase16    Decimal   @default(0) @map("taxable_base_16") @db.Decimal(15, 2)
  taxableBase0     Decimal   @default(0) @map("taxable_base_0") @db.Decimal(15, 2)
  exemptTotal      Decimal   @default(0) @map("exempt_total") @db.Decimal(15, 2)
  itbis18          Decimal   @default(0) @map("itbis_18") @db.Decimal(15, 2)
  itbis16          Decimal   @default(0) @map("itbis_16") @db.Decimal(15, 2)
  totalItbis       Decimal   @default(0) @map("total_itbis") @db.Decimal(15, 2)
  tipAmount        Decimal   @default(0) @map("tip_amount") @db.Decimal(15, 2)
  total            Decimal   @default(0) @db.Decimal(15, 2)
  amountPaid       Decimal   @default(0) @map("amount_paid") @db.Decimal(15, 2)
  balanceDue       Decimal   @default(0) @map("balance_due") @db.Decimal(15, 2)
  // Status
  status           String    @default("draft") @db.VarChar(20)
  // DGII
  dgiiTrackId      String?   @map("dgii_track_id") @db.VarChar(100)
  dgiiStatus       String?   @map("dgii_status") @db.VarChar(20)
  dgiiMessage      String?   @map("dgii_message")
  dgiiSentAt       DateTime? @map("dgii_sent_at") @db.Timestamptz()
  dgiiResponseAt   DateTime? @map("dgii_response_at") @db.Timestamptz()
  // Reference (for credit/debit notes)
  refInvoiceId     String?   @map("ref_invoice_id") @db.Uuid
  refEncf          String?   @map("ref_encf") @db.VarChar(13)
  refDate          DateTime? @map("ref_date") @db.Date
  modificationCode String?   @map("modification_code") @db.VarChar(5)
  // XML
  xmlContent       String?   @map("xml_content")
  xmlResponse      String?   @map("xml_response")
  // Metadata
  notes            String?
  internalNotes    String?   @map("internal_notes")
  paymentForm      String    @default("1") @map("payment_form") @db.VarChar(10)
  createdById      String    @map("created_by") @db.Uuid
  updatedById      String?   @map("updated_by") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  company          Company         @relation(fields: [companyId], references: [id])
  branch           Branch          @relation(fields: [branchId], references: [id])
  customer         Customer?       @relation(fields: [customerId], references: [id])
  ecfSequence      EcfSequence?    @relation(fields: [encfSeqId], references: [id])
  refInvoice       Invoice?        @relation("InvoiceReference", fields: [refInvoiceId], references: [id])
  referencedBy     Invoice[]       @relation("InvoiceReference")
  createdBy        User            @relation("InvoiceCreatedBy", fields: [createdById], references: [id])
  updatedBy        User?           @relation("InvoiceUpdatedBy", fields: [updatedById], references: [id])
  items            InvoiceItem[]
  payments         Payment[]
  transmissionLogs EcfTransmissionLog[]

  @@unique([companyId, encf])
  @@map("invoices")
}

model InvoiceItem {
  id             String   @id @default(uuid()) @db.Uuid
  invoiceId      String   @map("invoice_id") @db.Uuid
  productId      String?  @map("product_id") @db.Uuid
  lineNumber     Int      @map("line_number")
  description    String   @db.VarChar(500)
  quantity       Decimal  @db.Decimal(15, 4)
  unitId         String?  @map("unit_id") @db.Uuid
  unitPrice      Decimal  @map("unit_price") @db.Decimal(15, 4)
  discountPct    Decimal  @default(0) @map("discount_pct") @db.Decimal(5, 2)
  discountAmount Decimal  @default(0) @map("discount_amount") @db.Decimal(15, 2)
  isTaxable      Boolean  @default(true) @map("is_taxable")
  taxRate        Decimal  @default(18) @map("tax_rate") @db.Decimal(5, 2)
  taxAmount      Decimal  @default(0) @map("tax_amount") @db.Decimal(15, 2)
  subtotal       Decimal  @db.Decimal(15, 2)
  total          Decimal  @db.Decimal(15, 2)
  bienOServicio  String   @default("1") @map("bien_o_servicio") @db.VarChar(5)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()

  invoice Invoice        @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product?       @relation(fields: [productId], references: [id])
  unit    UnitOfMeasure? @relation(fields: [unitId], references: [id])

  @@map("invoice_items")
}

model Payment {
  id            String   @id @default(uuid()) @db.Uuid
  companyId     String   @map("company_id") @db.Uuid
  customerId    String?  @map("customer_id") @db.Uuid
  invoiceId     String?  @map("invoice_id") @db.Uuid
  paymentDate   DateTime @map("payment_date") @db.Date
  amount        Decimal  @db.Decimal(15, 2)
  paymentMethod String   @map("payment_method") @db.VarChar(30)
  reference     String?  @db.VarChar(100)
  bankAccount   String?  @map("bank_account") @db.VarChar(50)
  notes         String?
  status        String   @default("applied") @db.VarChar(20)
  createdById   String   @map("created_by") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()

  customer  Customer? @relation(fields: [customerId], references: [id])
  invoice   Invoice?  @relation(fields: [invoiceId], references: [id])
  createdBy User      @relation(fields: [createdById], references: [id])

  @@map("payments")
}

model EcfTransmissionLog {
  id            String   @id @default(uuid()) @db.Uuid
  invoiceId     String   @map("invoice_id") @db.Uuid
  encf          String   @db.VarChar(13)
  action        String   @db.VarChar(30)
  requestXml    String?  @map("request_xml")
  responseXml   String?  @map("response_xml")
  httpStatus    Int?     @map("http_status")
  trackId       String?  @map("track_id") @db.VarChar(100)
  dgiiStatus    String?  @map("dgii_status") @db.VarChar(30)
  errorMessage  String?  @map("error_message")
  attemptNumber Int      @default(1) @map("attempt_number")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@map("ecf_transmission_log")
}

// ============================================
// Compras
// ============================================

model PurchaseOrder {
  id           String    @id @default(uuid()) @db.Uuid
  companyId    String    @map("company_id") @db.Uuid
  supplierId   String    @map("supplier_id") @db.Uuid
  warehouseId  String    @map("warehouse_id") @db.Uuid
  orderNumber  String    @map("order_number") @db.VarChar(30)
  orderDate    DateTime  @map("order_date") @db.Date
  expectedDate DateTime? @map("expected_date") @db.Date
  currencyCode String    @default("DOP") @map("currency_code") @db.VarChar(3)
  exchangeRate Decimal   @default(1) @map("exchange_rate") @db.Decimal(15, 6)
  subtotal     Decimal   @default(0) @db.Decimal(15, 2)
  taxTotal     Decimal   @default(0) @map("tax_total") @db.Decimal(15, 2)
  total        Decimal   @default(0) @db.Decimal(15, 2)
  status       String    @default("draft") @db.VarChar(20)
  ncfSupplier  String?   @map("ncf_supplier") @db.VarChar(19)
  notes        String?
  createdById  String    @map("created_by") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  company   Company             @relation(fields: [companyId], references: [id])
  supplier  Supplier            @relation(fields: [supplierId], references: [id])
  warehouse Warehouse           @relation(fields: [warehouseId], references: [id])
  createdBy User                @relation(fields: [createdById], references: [id])
  items     PurchaseOrderItem[]

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String  @id @default(uuid()) @db.Uuid
  purchaseOrderId String  @map("purchase_order_id") @db.Uuid
  productId       String  @map("product_id") @db.Uuid
  quantity        Decimal @db.Decimal(15, 4)
  receivedQty     Decimal @default(0) @map("received_qty") @db.Decimal(15, 4)
  unitCost        Decimal @map("unit_cost") @db.Decimal(15, 4)
  taxRate         Decimal @default(18) @map("tax_rate") @db.Decimal(5, 2)
  taxAmount       Decimal @default(0) @map("tax_amount") @db.Decimal(15, 2)
  subtotal        Decimal @db.Decimal(15, 2)
  total           Decimal @db.Decimal(15, 2)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])

  @@map("purchase_order_items")
}

// ============================================
// SaaS Platform — Suscripciones y Facturación
// ============================================

enum PlanTier {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

enum BillingInvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

model Plan {
  id          String   @id @default(uuid()) @db.Uuid
  tier        PlanTier @unique
  name        String   @db.VarChar(100)
  description String?

  // Precios
  priceMonthly Decimal @map("price_monthly") @db.Decimal(10, 2)
  priceAnnual  Decimal @map("price_annual") @db.Decimal(10, 2)
  currency     String  @default("USD") @db.VarChar(3)

  // Límites de uso (null = ilimitado)
  maxUsers         Int? @map("max_users")
  maxBranches      Int? @map("max_branches")
  maxWarehouses    Int? @map("max_warehouses")
  maxInvoicesMonth Int? @map("max_invoices_month")
  maxProductsSku   Int? @map("max_products_sku")
  maxStorageGb     Int? @map("max_storage_gb")

  // Feature flags por plan
  hasEcfIntegration    Boolean @default(false) @map("has_ecf_integration")
  hasMultiBranch       Boolean @default(false) @map("has_multi_branch")
  hasApiAccess         Boolean @default(false) @map("has_api_access")
  hasAdvancedReports   Boolean @default(false) @map("has_advanced_reports")
  hasCustomRoles       Boolean @default(false) @map("has_custom_roles")
  hasPurchaseOrders    Boolean @default(false) @map("has_purchase_orders")
  hasPriceListMultiple Boolean @default(false) @map("has_price_list_multiple")
  hasPrioritySupport   Boolean @default(false) @map("has_priority_support")

  isPublic  Boolean @default(true)  @map("is_public")
  isActive  Boolean @default(true)  @map("is_active")
  sortOrder Int     @default(0)     @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt     @map("updated_at") @db.Timestamptz()

  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id           String             @id @default(uuid()) @db.Uuid
  companyId    String             @unique @map("company_id") @db.Uuid
  planId       String             @map("plan_id") @db.Uuid
  billingCycle BillingCycle       @map("billing_cycle")
  status       SubscriptionStatus @default(TRIALING)

  trialEndsAt        DateTime? @map("trial_ends_at") @db.Timestamptz()
  currentPeriodStart DateTime  @map("current_period_start") @db.Timestamptz()
  currentPeriodEnd   DateTime  @map("current_period_end") @db.Timestamptz()
  cancelledAt        DateTime? @map("cancelled_at") @db.Timestamptz()
  cancelAtPeriodEnd  Boolean   @default(false) @map("cancel_at_period_end")

  // Referencia a pasarela de pago externa (Stripe, Azul, PayPal, etc.)
  externalCustomerId     String? @map("external_customer_id") @db.VarChar(200)
  externalSubscriptionId String? @map("external_subscription_id") @db.VarChar(200)

  // Overrides por tenant (superadmin puede personalizar límites)
  overrideMaxUsers         Int? @map("override_max_users")
  overrideMaxInvoicesMonth Int? @map("override_max_invoices_month")

  notes     String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt     @map("updated_at") @db.Timestamptz()

  company         Company          @relation(fields: [companyId], references: [id])
  plan            Plan             @relation(fields: [planId], references: [id])
  billingInvoices BillingInvoice[]
  usageSnapshots  UsageSnapshot[]

  @@map("subscriptions")
}

// Captura de uso al cierre de cada ciclo (para enforcement y métricas)
model UsageSnapshot {
  id             String   @id @default(uuid()) @db.Uuid
  subscriptionId String   @map("subscription_id") @db.Uuid
  companyId      String   @map("company_id") @db.Uuid
  invoicesCount  Int      @default(0) @map("invoices_count")
  usersCount     Int      @default(0) @map("users_count")
  productsCount  Int      @default(0) @map("products_count")
  storageUsedMb  Int      @default(0) @map("storage_used_mb")
  periodStart    DateTime @map("period_start") @db.Timestamptz()
  periodEnd      DateTime @map("period_end") @db.Timestamptz()
  capturedAt     DateTime @default(now()) @map("captured_at") @db.Timestamptz()

  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@map("usage_snapshots")
}

// Facturas del SaaS (NO son facturas e-CF DGII — son recibos de la plataforma)
model BillingInvoice {
  id             String               @id @default(uuid()) @db.Uuid
  subscriptionId String               @map("subscription_id") @db.Uuid
  companyId      String               @map("company_id") @db.Uuid
  invoiceNumber  String               @map("invoice_number") @db.VarChar(30)
  status         BillingInvoiceStatus @default(DRAFT)
  billingCycle   BillingCycle         @map("billing_cycle")
  subtotal       Decimal              @db.Decimal(10, 2)
  taxAmount      Decimal              @default(0) @map("tax_amount") @db.Decimal(10, 2)
  total          Decimal              @db.Decimal(10, 2)
  currency       String               @default("USD") @db.VarChar(3)
  periodStart    DateTime             @map("period_start") @db.Timestamptz()
  periodEnd      DateTime             @map("period_end") @db.Timestamptz()
  dueDate        DateTime             @map("due_date") @db.Date
  paidAt         DateTime?            @map("paid_at") @db.Timestamptz()
  externalInvoiceId  String? @map("external_invoice_id") @db.VarChar(200)
  pdfUrl             String? @map("pdf_url") @db.VarChar(500)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime @updatedAt     @map("updated_at") @db.Timestamptz()

  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@map("billing_invoices")
}

// Feature flags personalizados por tenant (funcionalidades beta o exclusivas de un cliente)
model TenantFeatureFlag {
  id        String  @id @default(uuid()) @db.Uuid
  companyId String  @map("company_id") @db.Uuid
  feature   String  @db.VarChar(100)
  enabled   Boolean @default(true)
  // Notas para el equipo: por qué se activó, fecha acordada, si se planea lanzar general
  notes     String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, feature])
  @@map("tenant_feature_flags")
}


// ============================================
// Auditoria
// ============================================

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  companyId  String   @map("company_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  entityType String   @map("entity_type") @db.VarChar(50)
  entityId   String   @map("entity_id") @db.Uuid
  action     String   @db.VarChar(20)
  oldValues  Json?    @map("old_values")
  newValues  Json?    @map("new_values")
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@map("audit_log")
}
